{
  "version": 2,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/llms.txt",
      "destination": "/llms.txt"
    },
    {
      "source": "/blog",
      "missing": [{ "type": "host", "value": "landymaker-blog.vercel.app" }],
      "destination": "https://landymaker-blog.vercel.app/blog"
    },
    {
      "source": "/blog/:match*",
      "missing": [{ "type": "host", "value": "landymaker-blog.vercel.app" }],
      "destination": "https://landymaker-blog.vercel.app/blog/:match*"
    },
    {
      "source": "/_next/:match*",
      "missing": [{ "type": "host", "value": "landymaker-blog.vercel.app" }],
      "destination": "https://landymaker-blog.vercel.app/_next/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}